# Kani Smart Router – Environment Variables Example
# Copy to .env and fill in your values.
# This file is safe to commit; .env is gitignored.

# Required: at least one provider API key
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: additional provider keys (add as needed in docker-compose.yaml)
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# LOCAL_PROXY_API_KEY=your-local-proxy-key

# Optional: override log/data directory paths
# KANI_LOG_DIR=/path/to/log/dir
# KANI_DATA_DIR=/path/to/data/dir
